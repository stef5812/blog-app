generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  username        String   @unique
  displayName     String?
  bio             String?
  avatarUrl       String?
  bannerUrl       String?
  siteTitle       String?
  siteDescription String?
  themeAccent     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           Post[]

  @@index([username])
}

model Post {
  id                String     @id @default(cuid())
  userId            String
  blogProfileId     String
  title             String
  slug              String
  excerpt           String?
  coverImageUrl     String?
  coverMediaType    String?    // "image" or "video"
  coverThumbnailUrl String?
  contentJson       Json
  status            PostStatus @default(DRAFT)
  publishedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  blogProfile       BlogProfile @relation(fields: [blogProfileId], references: [id], onDelete: Cascade)

  @@unique([blogProfileId, slug])
  @@index([userId])
  @@index([status])
  @@index([publishedAt])
}