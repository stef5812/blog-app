generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  username        String   @unique
  displayName     String?
  bio             String?
  avatarUrl       String?
  bannerUrl       String?
  siteTitle       String?
  siteDescription String?
  themeAccent     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           Post[]
  subscriptions   BlogSubscription[]

  @@index([username])
}

model MediaItem {
  id           String   @id @default(cuid())
  userId       String
  postId       String?
  url          String
  mediaType    String   // "image" or "video"
  title        String?
  description  String?
  thumbnailUrl String?
  source       String   @default("gallery")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  post         Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
}

model PageVisit {
  id        Int      @id @default(autoincrement())
  visitorId String
  path      String
  title     String?
  referrer  String?
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model BlogSubscription {
  id         String   @id @default(cuid())
  authUserId String
  email      String
  blogId     String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  blog BlogProfile @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([authUserId, blogId])
}

model Post {
  id                String     @id @default(cuid())
  userId            String
  blogProfileId     String
  title             String
  slug              String
  excerpt           String?
  coverImageUrl     String?
  coverMediaType    String?
  coverThumbnailUrl String?
  contentJson       Json
  status            PostStatus @default(DRAFT)
  publishedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  blogProfile       BlogProfile @relation(fields: [blogProfileId], references: [id], onDelete: Cascade)
  mediaItems        MediaItem[]

  @@unique([blogProfileId, slug])
  @@index([userId])
  @@index([status])
  @@index([publishedAt])
}